# Example automations.yaml — for teams running their own scheduling
# infrastructure (cron, LaunchAgents, Kubernetes CronJobs, etc.).
#
# This is the level-five pattern. If you want simpler scheduling
# inside Claude itself — natural-language commands like "run this
# every Monday at 9am" — see ../scheduling-in-claude.md.
#
# Each entry defines: a name, the skill to invoke, a cron expression,
# any prerequisites (skill waits for upstream output to be fresh),
# and what to do on failure or when human review is needed.
#
# This is illustrative — a real config might have thirty or forty
# entries. The shape is what matters.

automations:

  - name: snapshot-data
    skill: /snapshot-data
    cron: "45 8 * * 1-5"            # 08:45 Monday–Friday
    description: Fetch the day's data from all sources into state/cache/.
    notify_on_failure: slack

  - name: customer-voice
    skill: /customer-voice
    cron: "0 9 * * 1,3,5"           # 09:00 Monday, Wednesday, Friday
    requires:
      - snapshot-data               # waits up to 15 minutes for snapshot to complete
    wait_minutes: 15
    description: Run the customer-voice pipeline for all active customers.
    notify_on_failure: slack

  - name: customer-voice-post
    skill: /post-cv-summary
    cron: "30 9 * * 1,3,5"          # 09:30 Mon/Wed/Fri
    requires:
      - customer-voice
    wait_minutes: 20
    description: Post the rollup summary to #product.

  - name: qa-review
    skill: /qa-observation-integrity
    cron: "0 8 * * 4"               # 08:00 Thursday
    requires:
      - customer-voice
    description: Run deterministic QA checks across all customer-voice reports.
    notify_on_failure: slack-dm     # ping me directly; this gates the week

  - name: release-notes-draft
    skill: /draft-release-notes
    cron: "45 10 * * 5"             # 10:45 Friday
    description: Draft release notes from the week's shipped PRs.
    review:
      channel: "#release-review"
      timeout_hours: 2              # human approval expected within 2 hours
      on_timeout: defer-to-monday   # don't ship without a sign-off

  - name: release-notes-finalize
    skill: /finalize-release-notes
    cron: "0 13 * * 5"              # 13:00 Friday
    requires:
      - release-notes-draft         # only runs after the review loop above approves
    description: Strip review annotations and send the final notes to customers.

  - name: weekly-slides
    skill: /weekly-slides
    cron: "45 16 * * 5"             # 16:45 Friday
    requires:
      - customer-voice
    description: Generate the weekly summary deck for Monday's review meeting.

# Two patterns worth noticing:
#
# 1. Dependencies use `requires:` + `wait_minutes:` — downstream jobs
#    poll for upstream completion instead of silently skipping when the
#    upstream is late. This handles the "snapshot ran two minutes late
#    today" case gracefully.
#
# 2. The `review:` block on release-notes-draft is the human-in-the-loop
#    pattern. The skill produces a draft, posts it to Slack, and waits.
#    The next skill (release-notes-finalize) only runs after the review
#    loop approves.
