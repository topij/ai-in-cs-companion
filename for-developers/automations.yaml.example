# Example automations.yaml — for teams running their own scheduling
# infrastructure (cron, LaunchAgents, Kubernetes CronJobs, etc.).
#
# This is the level-five pattern. If you want simpler scheduling
# inside Claude itself — natural-language commands like "run this
# every Monday at 9am" — see ../scheduling-in-claude.md.
#
# The field names and shape below mirror the production cs-toolkit's
# scheduler registry (a Python wrapper reads this file, generates the
# platform's scheduled jobs, enforces dependencies, and reports status).
# The jobs are illustrative; the schema is what actually runs every day.

automations:

  snapshot-data:
    description: "Fetch the day's data from all sources into state/cache/"
    command: "uv run scripts/snapshot_data.py --all"
    schedule: "weekdays 08:45"     # human-readable beats crontab syntax
    timeout: 1200                  # seconds; kill and alert past this
    notify_on_failure: true        # Slack DM on non-zero exit

  customer-voice:
    description: "Run the customer-voice pipeline for all active customers"
    # A list runs sequentially; each step only runs if the previous one
    # succeeded. Pair the LLM step with deterministic post-steps — the
    # quality rules you can't trust a model to apply on an unattended run.
    command:
      - "claude -p '/customer-voice mode: gather'"
      - "uv run scripts/apply_merge_rules.py"
    schedule:
      - "mon,wed 09:00"
      - "fri 10:15"                # multiple schedule strings are fine
    timeout: 3600
    notify_on_failure: true
    depends_on:
      - automation: snapshot-data
        max_staleness_hours: 4     # refuse to run on stale upstream data
        wait_minutes: 15           # poll for a late upstream before failing
        retries: 2                 # then two more polling windows
    git_commit:                    # auto-commit artifacts after success
      paths: ["reports/"]
      message: "customer-voice: scheduled run"
      push_branch: "auto/daily"    # machine-written work gets its own branch

  weekly-summary:
    description: "Generate the weekly summary for Monday's review meeting"
    command: "claude -p '/weekly-summary'"
    schedule: "fri 16:45"
    notify_on_failure: true
    depends_on:
      - automation: customer-voice
        max_staleness_hours: 12

# Patterns worth noticing — all production-proven:
#
# 1. depends_on + max_staleness_hours + wait_minutes: a downstream job
#    checks that upstream data is FRESH, and polls briefly for a late
#    upstream, instead of silently running on yesterday's cache.
#
# 2. command lists: deterministic post-steps run inside the same job as
#    the LLM step, so quality enforcement can't be skipped or forgotten.
#
# 3. git_commit + push_branch: machine-written output lands on a dedicated
#    branch that a human reviews and merges on a regular cadence — never
#    directly on the main branch.
#
# 4. Human review loops (drafts approved in Slack before anything is sent)
#    live in the *skills*, not in this registry: a skill posts a draft to a
#    review channel and a bot watches reactions. The scheduler only
#    sequences jobs.
